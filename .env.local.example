# Copy this file to .env.local and fill in your own Supabase project values.
# Find these in your Supabase dashboard: Project Settings > API

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Only needed locally to run scripts/seed.mjs — NEVER expose this in the browser
# or commit it to git. Put it in a separate .env file (not .env.local).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
